    {
      "name": "00-Setup",
      "item": [
        {
          "name": "[SETUP] Create Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Agent created with numeric ID\", function () {",
                  "    var jsonData = pm.response.json();",
                  "",
                  "    pm.expect(jsonData).to.have.property('agentId');",
                  "    pm.expect(jsonData.agentId).to.be.a('number');",
                  "",
                  "    pm.expect(jsonData.name).to.exist;",
                  "    pm.expect(jsonData.role).to.equal('AGENT');",
                  "    pm.expect(jsonData.status).to.equal('ACTIVE');",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.environment.set('agentId', pm.response.json().id);",
                  "}",
                  "",
                  "let json = pm.response.json();",
                  "pm.environment.set(\"agentId\", json.agentId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "eval(pm.globals.get(\"commonUtils\"));\r",
                  "\r",
                  "const agentEmail = generateUnique(\"agent\", \"usedAgentEmails\");\r",
                  "pm.environment.set(\"agentEmail\", `${agentEmail}@test.com`);\r",
                  "\r",
                  "const phone = \"+91\" + Math.floor(1000000000 + Math.random() * 9000000000);\r",
                  "pm.environment.set(\"phoneNumber\", phone);\r",
                  "console.log(\"Generated Email:\", pm.environment.get(\"agentEmail\"));\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Agent {{$timestamp}}\",\n  \"email\": \"{{agentEmail}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"role\": \"AGENT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/agents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "agents"
              ]
            }
          },
          "response": []
